<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="Antigravity" version="24.0.0" type="device">
  <diagram id="axi_arch" name="AXI4-Lite Wrapper Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;AXI4-Lite Wrapper Architecture &amp;amp; Testbench&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=22;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="600" height="40" as="geometry" />
        </mxCell>

        <!-- riscv_axi_top Box -->
        <mxCell id="axi_top" value="&lt;b&gt;riscv_axi_top&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=14;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="680" height="520" as="geometry" />
        </mxCell>

        <!-- riscv_core Box -->
        <mxCell id="core" value="&lt;b&gt;riscv_core&lt;/b&gt;&lt;br&gt;(5-Stage Pipeline)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="120" y="160" width="200" height="400" as="geometry" />
        </mxCell>

        <!-- AXI Master IF -->
        <mxCell id="axi_master_if" value="&lt;b&gt;riscv_axi_master&lt;/b&gt;&lt;br&gt;(IF Stage)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="460" y="180" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- AXI Master MEM -->
        <mxCell id="axi_master_mem" value="&lt;b&gt;riscv_axi_master&lt;/b&gt;&lt;br&gt;(MEM Stage)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="460" y="400" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Connections from Core to Masters -->
        <mxCell id="conn_core_if_req" value="imem_addr, req" style="endArrow=classic;html=1;entryX=0;entryY=0.25;entryDx=0;entryDy=0;exitX=1;exitY=0.15;exitDx=0;exitDy=0;" edge="1" parent="1" source="core" target="axi_master_if">
          <mxGeometry width="50" height="50" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn_core_if_resp" value="imem_rdata, stall_if" style="endArrow=classic;html=1;entryX=1;entryY=0.35;entryDx=0;entryDy=0;exitX=0;exitY=0.75;exitDx=0;exitDy=0;" edge="1" parent="1" source="axi_master_if" target="core">
          <mxGeometry width="50" height="50" relative="1" as="geometry" />
        </mxCell>

        <mxCell id="conn_core_mem_req" value="dmem_addr, we, wdata, req" style="endArrow=classic;html=1;entryX=0;entryY=0.25;entryDx=0;entryDy=0;exitX=1;exitY=0.65;exitDx=0;exitDy=0;" edge="1" parent="1" source="core" target="axi_master_mem">
          <mxGeometry width="50" height="50" relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn_core_mem_resp" value="dmem_rdata, stall_mem" style="endArrow=classic;html=1;entryX=1;entryY=0.85;entryDx=0;entryDy=0;exitX=0;exitY=0.75;exitDx=0;exitDy=0;" edge="1" parent="1" source="axi_master_mem" target="core">
          <mxGeometry width="50" height="50" relative="1" as="geometry" />
        </mxCell>

        <!-- Testbench Box -->
        <mxCell id="tb" value="&lt;b&gt;tb_riscv_axi&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=14;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="840" y="100" width="300" height="520" as="geometry" />
        </mxCell>

        <!-- AXI Slave IF -->
        <mxCell id="axi_slave_if" value="&lt;b&gt;riscv_axi_memory_slave&lt;/b&gt;&lt;br&gt;(IMEM)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="880" y="180" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- AXI Slave MEM -->
        <mxCell id="axi_slave_mem" value="&lt;b&gt;riscv_axi_memory_slave&lt;/b&gt;&lt;br&gt;(DMEM)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="880" y="400" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- Connections from Masters to Slaves -->
        <mxCell id="conn_axi_if" value="m_axi_imem_* (AR, R Channels)" style="endArrow=classic;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;startArrow=classic;startFill=1;" edge="1" parent="1" source="axi_master_if" target="axi_slave_if">
          <mxGeometry width="50" height="50" relative="1" as="geometry" />
        </mxCell>

        <mxCell id="conn_axi_mem" value="m_axi_dmem_* (AW, W, B, AR, R)" style="endArrow=classic;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;startArrow=classic;startFill=1;" edge="1" parent="1" source="axi_master_mem" target="axi_slave_mem">
          <mxGeometry width="50" height="50" relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
